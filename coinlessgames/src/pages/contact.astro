---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with Coinless Games.">
  <section class="wrap page">
    <p class="eyebrow">// SEND MESSAGE</p>
    <h1>Contact</h1>
    <p class="intro">
      Questions, feedback, bug reports, or just want to say hi — drop a note below.
    </p>

    <form
      name="contact"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      action="/contact/thanks"
      class="contact-form"
    >
      <input type="hidden" name="form-name" value="contact" />
      <p class="hidden-field">
        <label>Don't fill this out if you're human: <input name="bot-field" /></label>
      </p>

      <label class="field">
        <span class="field-label">NAME</span>
        <input type="text" name="name" required />
      </label>

      <label class="field">
        <span class="field-label">EMAIL</span>
        <input type="email" name="email" required />
      </label>

      <label class="field">
        <span class="field-label">MESSAGE</span>
        <textarea name="message" rows="6" required></textarea>
      </label>

      <button type="submit" class="submit-btn">SEND</button>
    </form>
  </section>

  <style>
    .page {
      padding: 3rem 1.5rem 4rem;
    }

    .eyebrow {
      font-size: 0.75rem;
      color: var(--color-marquee);
      letter-spacing: 1px;
      font-weight: 700;
      margin: 0 0 0.5rem;
    }

    h1 {
      margin-top: 0;
      margin-bottom: 0.75rem;
    }

    .intro {
      color: var(--color-text-muted);
      margin-bottom: 2rem;
    }

    .hidden-field {
      position: absolute;
      left: -9999px;
    }

    .contact-form {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      max-width: 520px;
    }

    .field {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }

    .field-label {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 1px;
      color: var(--color-text-muted);
    }

    input, textarea {
      font-family: var(--font-body);
      font-size: 0.95rem;
      background: var(--color-bg-raised);
      border: 2px solid var(--color-border);
      border-radius: var(--radius);
      color: var(--color-text);
      padding: 0.7rem 0.85rem;
      resize: vertical;
    }

    input:focus, textarea:focus {
      outline: none;
      border-color: var(--color-accent);
    }

    .submit-btn {
      align-self: flex-start;
      font-family: var(--font-display);
      font-size: 0.75rem;
      background: var(--color-accent);
      color: var(--color-bg);
      border: none;
      padding: 0.9rem 1.75rem;
      border-radius: var(--radius);
      cursor: pointer;
      letter-spacing: 1px;
      transition: transform 0.1s ease, background 0.15s ease;
    }

    .submit-btn:hover {
      background: var(--color-marquee);
      transform: translateY(-2px);
    }
  </style>
</BaseLayout>
