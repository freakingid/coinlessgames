---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Home">
  <section class="marquee wrap">
    <div class="cabinet pixel-corners">
      <p class="marquee-eyebrow" id="marquee-text">INSERT COIN TO CONTINUE</p>
      <h1>COINLESS GAMES</h1>
      <p class="tagline">Small games, made by hand, no coin slot required.</p>
      <button class="press-start" id="press-start">PRESS START</button>
    </div>
  </section>

  <section class="wrap intro">
    <h2>// WHAT THIS IS</h2>
    <p>
      This is the home base for the games I build on my own time — experiments,
      finished releases, and everything in between. No monetized coin-op
      machine here, just games made because they were fun to make.
    </p>
  </section>

  {posts.length > 0 && (
    <section class="wrap latest">
      <h2>// LATEST FROM THE DEVLOG</h2>
      <ul class="post-list">
        {posts.map((post) => (
          <li class="post-row">
            <a href={`/blog/${post.slug}`} class="post-link">{post.data.title}</a>
            <span class="post-date">{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
          </li>
        ))}
      </ul>
      <a href="/blog" class="more-link">SEE ALL ENTRIES →</a>
    </section>
  )}

  <script>
    const btn = document.getElementById('press-start');
    const marqueeText = document.getElementById('marquee-text');
    let pressed = false;

    btn?.addEventListener('click', () => {
      if (pressed) return;
      pressed = true;
      if (marqueeText) {
        marqueeText.textContent = 'NO COIN REQUIRED';
        marqueeText.classList.add('marquee-eyebrow--flipped');
      }
      btn.textContent = 'THANKS FOR PLAYING';
      btn.setAttribute('disabled', 'true');
    });
  </script>

  <style>
    .marquee {
      padding-top: 3rem;
      padding-bottom: 2rem;
    }

    .cabinet {
      background: var(--color-bg-raised);
      border: 3px solid var(--color-border);
      padding: 3rem 2rem;
      text-align: center;
      position: relative;
    }

    .cabinet::before {
      content: '';
      position: absolute;
      inset: 10px;
      border: 1px dashed var(--color-border);
      pointer-events: none;
    }

    .marquee-eyebrow {
      font-family: var(--font-display);
      font-size: 0.65rem;
      color: var(--color-marquee);
      letter-spacing: 2px;
      margin: 0 0 1.5rem;
      animation: blink 1.4s steps(1) infinite;
    }

    .marquee-eyebrow--flipped {
      color: var(--color-accent);
      animation: none;
    }

    @keyframes blink {
      0%, 49% { opacity: 1; }
      50%, 100% { opacity: 0.25; }
    }

    h1 {
      font-size: clamp(1.4rem, 5vw, 2.2rem);
      color: var(--color-accent);
      margin: 0 0 1rem;
      text-shadow: 0 0 12px rgba(74, 222, 128, 0.35);
    }

    .tagline {
      color: var(--color-text-muted);
      margin: 0 0 2rem;
      font-size: 0.95rem;
    }

    .press-start {
      font-family: var(--font-display);
      font-size: 0.75rem;
      background: var(--color-accent);
      color: var(--color-bg);
      border: none;
      padding: 0.9rem 1.75rem;
      border-radius: var(--radius);
      cursor: pointer;
      letter-spacing: 1px;
      transition: transform 0.1s ease, background 0.15s ease;
    }

    .press-start:hover:not(:disabled) {
      background: var(--color-marquee);
      transform: translateY(-2px);
    }

    .press-start:disabled {
      background: var(--color-border);
      color: var(--color-text-muted);
      cursor: default;
    }

    .intro {
      padding-top: 2rem;
      padding-bottom: 1rem;
    }

    .latest {
      padding-top: 2rem;
      padding-bottom: 3rem;
    }

    .post-list {
      list-style: none;
      padding: 0;
      margin: 1rem 0;
      border-top: 1px solid var(--color-border);
    }

    .post-row {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 1rem;
      padding: 0.85rem 0;
      border-bottom: 1px solid var(--color-border);
    }

    .post-link {
      color: var(--color-text);
      text-decoration: none;
    }

    .post-link:hover {
      color: var(--color-accent);
      text-decoration: underline;
    }

    .post-date {
      font-size: 0.75rem;
      color: var(--color-text-muted);
      white-space: nowrap;
    }

    .more-link {
      display: inline-block;
      margin-top: 0.5rem;
      font-size: 0.85rem;
      font-weight: 700;
    }
  </style>
</BaseLayout>
