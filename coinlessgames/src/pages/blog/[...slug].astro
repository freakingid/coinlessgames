---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<BaseLayout title={post.data.title} description={post.data.summary}>
  <article class="wrap page">
    <a href="/blog" class="back-link">← BACK TO DEVLOG</a>
    <p class="post-date">{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</p>
    <h1>{post.data.title}</h1>
    <div class="prose">
      <Content />
    </div>
  </article>

  <style>
    .page {
      padding: 3rem 1.5rem 4rem;
    }

    .back-link {
      display: inline-block;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.5px;
      margin-bottom: 1.5rem;
    }

    .post-date {
      font-size: 0.75rem;
      color: var(--color-text-muted);
      margin: 0 0 0.5rem;
    }

    h1 {
      margin-top: 0;
      margin-bottom: 2rem;
    }

    .prose :global(h2) {
      margin-top: 2rem;
    }

    .prose :global(p) {
      margin: 0 0 1.1rem;
    }

    .prose :global(img) {
      max-width: 100%;
      border-radius: var(--radius);
      border: 2px solid var(--color-border);
    }

    .prose :global(a) {
      word-break: break-word;
    }

    .prose :global(code) {
      background: var(--color-bg-raised);
      padding: 0.15rem 0.4rem;
      border-radius: 3px;
      font-size: 0.85em;
    }

    .prose :global(pre) {
      background: var(--color-bg-inset);
      padding: 1rem;
      border-radius: var(--radius);
      overflow-x: auto;
      border: 1px solid var(--color-border);
    }

    .prose :global(blockquote) {
      border-left: 3px solid var(--color-accent);
      margin: 1.5rem 0;
      padding-left: 1rem;
      color: var(--color-text-muted);
    }
  </style>
</BaseLayout>
