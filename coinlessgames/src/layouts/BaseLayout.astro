---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Coinless Games — indie games made without the coin slot.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} · Coinless Games</title>
  </head>
  <body>
    <header class="site-header">
      <div class="wrap header-inner">
        <a href="/" class="logo">
          <span class="logo-bracket">[</span>COINLESS<span class="logo-bracket">]</span>
        </a>
        <nav class="cab-nav" aria-label="Main navigation">
          <a href="/" class="cab-btn">HOME</a>
          <a href="/about" class="cab-btn">ABOUT</a>
          <a href="/blog" class="cab-btn">DEVLOG</a>
          <a href="/contact" class="cab-btn cab-btn--accent">CONTACT</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wrap footer-inner">
        <p class="footer-line">© {new Date().getFullYear()} Coinless Games — no coin required.</p>
        <p class="footer-line footer-line--muted">Built without a database. Runs on nothing but static files and stubbornness.</p>
      </div>
    </footer>

    <style>
      .site-header {
        border-bottom: 2px solid var(--color-border);
        background: var(--color-bg-inset);
        position: sticky;
        top: 0;
        z-index: 10;
      }

      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.75rem;
        padding-top: 1rem;
        padding-bottom: 1rem;
      }

      .logo {
        font-family: var(--font-display);
        font-size: 0.85rem;
        color: var(--color-accent);
        text-decoration: none;
        letter-spacing: 1px;
        white-space: nowrap;
      }

      .logo:hover {
        color: var(--color-marquee);
      }

      .logo-bracket {
        color: var(--color-text-muted);
      }

      .cab-nav {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
      }

      .cab-btn {
        font-family: var(--font-body);
        font-weight: 700;
        font-size: 0.7rem;
        letter-spacing: 1px;
        text-decoration: none;
        color: var(--color-text);
        background: var(--color-bg-raised);
        border: 2px solid var(--color-border);
        padding: 0.5rem 0.75rem;
        border-radius: var(--radius);
        transition: transform 0.1s ease, border-color 0.15s ease, color 0.15s ease;
        display: inline-block;
      }

      .cab-btn:hover {
        color: var(--color-accent);
        border-color: var(--color-accent);
        transform: translateY(-2px);
        text-decoration: none;
      }

      .cab-btn--accent {
        border-color: var(--color-accent-rare);
        color: var(--color-accent-rare);
      }

      .cab-btn--accent:hover {
        color: var(--color-accent-rare);
        border-color: var(--color-accent-rare);
        box-shadow: 0 0 0 2px rgba(255, 107, 157, 0.2);
      }

      .site-footer {
        border-top: 2px solid var(--color-border);
        margin-top: 4rem;
        padding: 2rem 0;
      }

      .footer-inner {
        text-align: center;
      }

      .footer-line {
        margin: 0.25rem 0;
        font-size: 0.8rem;
      }

      .footer-line--muted {
        color: var(--color-text-muted);
      }
    </style>
  </body>
</html>
